# Configuração - Sistema de Reservas Parque Temático

# ========== API ==========
# Ambiente (development, test, production)
RACK_ENV=development

# Porta da API (padrão: 4567)
API_PORT=4567

# ========== FRONTEND ==========
# Porta do Frontend (padrão: 3000)
FRONTEND_PORT=3000

# URL da API para o frontend
VITE_API_URL=http://localhost:4567

# ========== DOCKER ==========
# Versão da imagem
IMAGE_TAG=1.0.0

# Registry (para push em cloud)
DOCKER_REGISTRY=docker.io
DOCKER_USERNAME=seu-usuario

# ========== LOGS ==========
# Nível de log (debug, info, warn, error)
LOG_LEVEL=info

# ========== SEGURANÇA ==========
# Chave secreta (altere em produção)
SECRET_KEY=seu-secret-key-muito-longo-e-seguro

# Token de autenticação
AUTH_TOKEN=seu-auth-token
